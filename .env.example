# DogCareAI Environment Variables
# Copy this file to .env.local and fill in local values.
# Never commit real secrets.

# ------------------------------------------------------------
# Frontend-safe variables
# These may be used by the React/Vite frontend.
# ------------------------------------------------------------

VITE_APP_ENV=development
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Debounce chat sends to reduce accidental duplicate AI calls.
VITE_CHAT_DEBOUNCE_MS=800
VITE_ENABLE_EMERGENCY_PRECHECK=true

# ------------------------------------------------------------
# AI behavior
# MOCK_AI_MODE=true allows development/testing/demo without AI API calls.
# These variables are intended for serverless/edge function usage.
# Keep MOCK_AI_MODE=true unless intentionally testing real Gemini.
# ------------------------------------------------------------

MOCK_AI_MODE=true
AI_MODEL=gemini-2.5-flash
AI_MAX_CONTEXT_ITEMS=8
AI_MAX_INPUT_CHARS=6000
AI_REQUEST_TIMEOUT_MS=12000

# Optional server-side safety guard.
# Keep this configurable because Gemini free-tier limits are model-dependent.
AI_RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=10

# ------------------------------------------------------------
# Server-side only variables
# These must never be exposed in frontend code.
# Use only in Vercel Functions / serverless functions.
# GEMINI_API_KEY is server-side only. Do not prefix it with VITE_.
# In Vercel, add these in Project Settings -> Environment Variables.
# Real secrets must not be committed.
# ------------------------------------------------------------

GEMINI_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# SUPABASE_SERVICE_ROLE_KEY is intentionally not required for the beta Gemini boundary.
# Do not use service-role keys in frontend code or this Step 8B Vercel Function.

# ------------------------------------------------------------
# Optional app configuration
# ------------------------------------------------------------

CLIENT_URL=http://localhost:5173

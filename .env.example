# DogCareAI Environment Variables
# Copy this file to .env.local and fill in local values.
# Never commit real secrets.

# ------------------------------------------------------------
# Frontend-safe variables
# These may be used by the React/Vite frontend.
# ------------------------------------------------------------

VITE_APP_ENV=development
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Debounce chat sends to reduce accidental duplicate AI calls.
VITE_CHAT_DEBOUNCE_MS=800
VITE_ENABLE_EMERGENCY_PRECHECK=true

# ------------------------------------------------------------
# AI behavior
# MOCK_AI_MODE=true allows development/testing/demo without AI API calls.
# These variables are intended for serverless/edge function usage.
# ------------------------------------------------------------

MOCK_AI_MODE=true
AI_MODEL=your_configured_gemini_model
AI_MAX_CONTEXT_ITEMS=8
AI_MAX_INPUT_CHARS=6000
AI_REQUEST_TIMEOUT_MS=20000

# Optional server-side safety guard.
# Keep this configurable because Gemini free-tier limits are model-dependent.
AI_RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=10

# ------------------------------------------------------------
# Server-side only secrets
# These must never be exposed in frontend code.
# Use only in Supabase Edge Functions / serverless functions.
# ------------------------------------------------------------

GEMINI_API_KEY=your_server_side_gemini_api_key
SUPABASE_SERVICE_ROLE_KEY=your_server_side_service_role_key_if_needed

# ------------------------------------------------------------
# Optional app configuration
# ------------------------------------------------------------

CLIENT_URL=http://localhost:5173
